# Agent Name
AGENT_NAME=Claw26-Team210-Onboarding-Agent

# Web Server Port Configuration
PORT=3000

# VNG Cloud AI Platform (MaaS) API Key and Base URL - Required
AI_PLATFORM_API_KEY=YOUR_AI_PLATFORM_API_KEY
AI_PLATFORM_BASE_URL=YOUR_AI_PLATFORM_BASE_URL

# System Prompt to shape the Agent's behavior/personality
SYSTEM_PROMPT="You are Jarvis, a polite and smart AI assistant built using TypeScript and Vercel AI SDK."

ATLASSIAN_DOMAIN="your-domain"
ATLASSIAN_EMAIL="your-email@company.com"
ATLASSIAN_API_TOKEN="your_atlassian_api_token"

GREENNODE_CLIENT_ID=your_greennode_client_id
GREENNODE_CLIENT_SECRET=your_greennode_client_secret

# Zalo Bot Configuration
ZALO_BOT_TOKEN="YOUR_ZALO_BOT_TOKEN"
ZALO_BOT_POLLING="true" # Set to "true" to use polling locally, or "false" to use webhooks
ZALO_WEBHOOK_SECRET_TOKEN="YOUR_ZALO_WEBHOOK_SECRET_TOKEN"
ZALO_WEBHOOK_URL="https://your-public-domain-or-ngrok/webhook/zalo"